@startuml
left to right direction
skinparam packageStyle rectangle
skinparam monochrome true
skinparam shadowing false

actor "User (Trader)" as Trader
actor "Binance Exchange" as Binance <<System>>

rectangle "QUANTFLOW System" {
    package "Access" {
        usecase "UC-01: Login" as UC01
    }

    package "Configuration" {
        usecase "UC-02: Update Account Info" as UC02
        usecase "UC-03: Configure API Keys" as UC03
        usecase "Validate API Keys" as UC03_Validate
    }

    package "Strategy Builder" {
        usecase "UC-04: Design Strategy (Low-code)" as UC04
        usecase "UC-05: Manage Strategy Templates\n(CRUD, Import/Export JSON)" as UC05
    }

    package "Backtest Engine" {
        usecase "UC-06: Run Backtest" as UC06
        usecase "UC-07: View Backtest Performance Report" as UC07
    }

    package "Live Trade Operation" {
        usecase "UC-08: Manage Bot Instance\n(Start/Stop)" as UC08
        usecase "UC-09: Monitor Live Bot" as UC09
        usecase "Execute Orders" as ExecOrder
        usecase "Sync Market Data" as SyncData
    }

    package "Monitoring" {
        usecase "UC-10: View Market" as UC10
        usecase "UC-11: View Trade History" as UC11
    }

    ' Internal System Relationships
    UC06 ..> UC07 : <<include>>
    UC08 ..> ExecOrder : <<include>>
    UC09 ..> SyncData : <<include>>
    UC03 <.. UC03_Validate : <<extend>>
}

' Actor Interactions
Trader -- UC01
Trader -- UC02
Trader -- UC03
Trader -- UC04
Trader -- UC05
Trader -- UC06
Trader -- UC08
Trader -- UC09
Trader -- UC10
Trader -- UC11

' External Interactions
UC03_Validate -- Binance
ExecOrder -- Binance : "REST API / WS"
SyncData -- Binance : "WebSocket"

@enduml