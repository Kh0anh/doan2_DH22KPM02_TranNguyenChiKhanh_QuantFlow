# ============================================================
# QuantFlow - Cau hinh Moi truong
# ============================================================
# Tac gia: Khanh
# Du an:   QuantFlow - Nen tang Low-code Giao dich Tu dong
#
# HUONG DAN:
#   1. Sao chep file nay thanh .env:  cp .env.example .env
#   2. Gan nhu KHONG CAN thay doi gi de chay development
#   3. KHONG BAO GIO commit file .env len Git
#
# Mac dinh file nay da san sang chay cho moi truong phat trien.
# Neu muon tuy chinh, chi can thay doi gia tri tuong ung.
# ============================================================


# =====================================================
# CO SO DU LIEU (PostgreSQL)
# =====================================================
# Thong tin dang nhap PostgreSQL (doi khi len production)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123
POSTGRES_DB=postgres


# =====================================================
# BACKEND (Go)
# =====================================================

# Che do chay: development | production
GO_ENV=development

# Ket noi CSDL (su dung ten container 'postgres' trong Docker network)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123
DB_NAME=postgres
# Che do SSL cho CSDL: disable (dev) | require (production)
DB_SSLMODE=disable

# Khoa bi mat JWT - dung de tao va xac thuc token dang nhap
# Tao moi bang: openssl rand -base64 32
JWT_SECRET=081f0a7bd0b61ecbe1e1ed68a99b3e01f6ecee328999d059b81fe60817eba6a3

# Khoa ma hoa AES-256 - dung de ma hoa API Key san giao dich
# PHAI dung 32 bytes. Tao moi bang: openssl rand -hex 32
AES_KEY=53e17d6c41f81ad01897c18032d4f5f7!!

# URL API Binance Futures
# Mainnet (that):  https://fapi.binance.com
# Testnet (demo):  https://demo-fapi.binance.com
BINANCE_API_BASE=https://demo-fapi.binance.com

# Cong backend (noi bo, proxy qua Nginx)
SERVER_PORT=8080

# Danh sach domain cho phep CORS (cach nhau bang dau phay, khong co khoang trang)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# Cap do log: debug | info | warn | error
LOG_LEVEL=info

# Danh sach cap tien theo doi (cach nhau bang dau phay)
WATCHED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT


# =====================================================
# FRONTEND (Next.js)
# =====================================================

# Che do chay: development | production
NODE_ENV=development

# Duong dan API (hien thi tren trinh duyet)
# Development: http://localhost/api/v1 (qua Nginx proxy)
# Production:  https://tenmien.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Duong dan WebSocket (hien thi tren trinh duyet)
# Development: ws://localhost/ws (qua Nginx proxy)
# Production:  wss://tenmien.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# Cong frontend (noi bo, proxy qua Nginx)
PORT=3000


# =====================================================
# DOCKER COMPOSE
# =====================================================
# Ten du an Docker Compose
COMPOSE_PROJECT_NAME=quantflow


# =====================================================
# CAU HINH PRODUCTION (Bo comment khi trien khai that)
# =====================================================

# Ten mien
# DOMAIN=quantflow.tenmien.com

# Email Let's Encrypt (dung gia han chung chi SSL)
# LETSENCRYPT_EMAIL=admin@tenmien.com


# =====================================================
# TUY CHINH NANG CAO (Khong bat buoc)
# =====================================================

# Hieu suat PostgreSQL
# POSTGRES_MAX_CONNECTIONS=100
# POSTGRES_SHARED_BUFFERS=256MB

# Hieu suat Backend
# GO_MAX_PROCS=4
# GOMEMLIMIT=512MiB

# Cau hinh phien dang nhap
# JWT_EXPIRATION_HOURS=24
# REFRESH_TOKEN_EXPIRATION_DAYS=7

# Gioi han toc do truy cap (Rate Limiting)
# RATE_LIMIT_REQUESTS_PER_SECOND=100
# RATE_LIMIT_BURST=20
