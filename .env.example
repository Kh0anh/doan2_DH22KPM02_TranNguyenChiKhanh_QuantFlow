# ============================================================
# QuantFlow Environment Variables Template
# ============================================================
# Author: Khanh
# Date: March 7, 2026
# Project: QuantFlow
# Description: Environment configuration for Docker Compose stack
# 
# IMPORTANT: 
# 1. Copy this file to .env (it's gitignored)
# 2. Replace all placeholder values with your actual secrets
# 3. NEVER commit .env to version control
#
# Usage: 
# cp .env.example .env
# nano .env  # Edit with your actual values
# ============================================================

# ===========================
# PostgreSQL Database Configuration
# ===========================
# Database credentials (Change in production!)
POSTGRES_USER=quantflow_user
POSTGRES_PASSWORD=quantflow_secure_password_2026_CHANGE_ME
POSTGRES_DB=quantflow_db

# ===========================
# Backend (Go) Configuration
# ===========================
# Environment mode (development | production)
GO_ENV=development

# Database connection (Use container name 'postgres' for Docker network)
DB_HOST=postgres
DB_PORT=5432
DB_USER=quantflow_user
DB_PASSWORD=quantflow_secure_password_2026_CHANGE_ME
DB_NAME=quantflow_db
DB_SSLMODE=disable  # Use 'require' in production

# JWT Token Secret (MUST be at least 32 characters in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_MINIMUM_32_characters_CHANGE_ME_IN_PRODUCTION

# AES-256 Encryption Key (MUST be exactly 32 bytes for AES-256)
# Generate with: openssl rand -hex 32
AES_KEY=your_aes_256_key_32_bytes_exactly_CHANGE_ME_IN_PRODUCTION!!

# Binance API Base URL (Futures Testnet for development)
# Production: https://fapi.binance.com
# Testnet: https://testnet.binancefuture.com
BINANCE_API_BASE=https://fapi.binance.com

# Backend Server Configuration
SERVER_PORT=8080

# CORS Allowed Origins (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# Logging Level (debug | info | warn | error)
LOG_LEVEL=info

# ===========================
# Frontend (Next.js) Configuration
# ===========================
# Environment mode (development | production)
NODE_ENV=development

# API Endpoint (Public - exposed to browser)
# Development: http://localhost/api/v1 (via Nginx proxy)
# Production: https://yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# WebSocket Endpoint (Public - exposed to browser)
# Development: ws://localhost/ws (via Nginx proxy)
# Production: wss://yourdomain.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# Next.js Server Port (Internal - proxied by Nginx)
PORT=3000

# ===========================
# Production Only Configuration
# ===========================
# Uncomment and configure when deploying to production

# SSL/TLS Configuration
# NGINX_SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# NGINX_SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# Domain Configuration
# DOMAIN=quantflow.yourdomain.com

# Let's Encrypt Email (for certificate renewal)
# LETSENCRYPT_EMAIL=admin@yourdomain.com

# ===========================
# Optional: Advanced Configuration
# ===========================

# PostgreSQL Performance Tuning
# POSTGRES_MAX_CONNECTIONS=100
# POSTGRES_SHARED_BUFFERS=256MB
# POSTGRES_EFFECTIVE_CACHE_SIZE=1GB

# Backend Performance
# GO_MAX_PROCS=4
# GOMEMLIMIT=512MiB

# Rate Limiting
# RATE_LIMIT_REQUESTS_PER_SECOND=100
# RATE_LIMIT_BURST=20

# Session Configuration
# JWT_EXPIRATION_HOURS=24
# REFRESH_TOKEN_EXPIRATION_DAYS=7

# ===========================
# Development Tools (Optional)
# ===========================
# Enable if you want to expose PostgreSQL port for local DB client
# EXPOSE_POSTGRES_PORT=5432

# Enable if you want to expose Backend port for direct API access
# EXPOSE_BACKEND_PORT=8080

# Enable if you want to expose Frontend port
# EXPOSE_FRONTEND_PORT=3000

# ===========================
# Docker Compose Configuration
# ===========================
# Compose project name (optional)
COMPOSE_PROJECT_NAME=quantflow

# ===========================
# Notes
# ===========================
# 1. JWT_SECRET: Minimum 32 characters, use strong random string
# 2. AES_KEY: Must be EXACTLY 32 bytes (64 hex characters) for AES-256
# 3. POSTGRES_PASSWORD: Use strong password with mix of chars, numbers, symbols
# 4. In production, set GO_ENV=production and NODE_ENV=production
# 5. In production, use HTTPS (wss://) for WebSocket connections
# 6. Change DB_SSLMODE to 'require' in production for encrypted DB connections
