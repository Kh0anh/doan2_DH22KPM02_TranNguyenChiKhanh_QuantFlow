# ============================================================
# QuantFlow Backend — Environment Variables Template
# ============================================================
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# ⚠️  NEVER commit the actual `.env` file to version control.
#     This template file is safe to commit.
# ============================================================

# ── Server ──────────────────────────────────────────────────
GO_ENV=development
SERVER_PORT=8080

# ── PostgreSQL Database ──────────────────────────────────────
# In Docker Compose, DB_HOST must match the service name ("postgres").
# For local `go run .` outside Docker, use "localhost".
DB_HOST=localhost
DB_PORT=5432
DB_USER=quantflow_user
DB_PASSWORD=quantflow_secure_password_2026
DB_NAME=quantflow_db
DB_SSLMODE=disable

# ── JWT Authentication ───────────────────────────────────────
# Must be at least 32 characters. Used to sign & verify JWT tokens.
# Generate a strong key: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_min_32_chars_development_only

# ── AES-256 Encryption ───────────────────────────────────────
# Must be EXACTLY 32 bytes (256 bits) for AES-256-GCM.
# Used to encrypt Exchange API Secret Keys at rest.
# Generate: openssl rand -hex 16  (produces 32 hex chars = 16 bytes raw)
# Or use a 32-character ASCII string.
AES_KEY=your_aes_256_key_32_bytes_exactly!!

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In Docker Compose, the Frontend is proxied by Nginx so localhost is sufficient.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ── Binance Futures API ──────────────────────────────────────
# Switch to Testnet URL for integration testing (task 4.1.3).
# Mainnet:  https://fapi.binance.com
# Testnet:  https://testnet.binancefuture.com
BINANCE_API_BASE=https://fapi.binance.com
